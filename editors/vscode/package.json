{
  "name": "simdref",
  "displayName": "simdref — SIMD intrinsic & instruction reference",
  "description": "Hover docs, completion, and microarchitecture performance data for SIMD intrinsics and assembly mnemonics (x86, Arm Neon/SVE, RISC-V V).",
  "version": "0.1.0",
  "publisher": "simdref",
  "license": "GPL-3.0-or-later",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "simd",
    "intrinsics",
    "avx",
    "neon",
    "sve",
    "rvv",
    "assembly"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DiamonDinoia/simdref"
  },
  "bugs": {
    "url": "https://github.com/DiamonDinoia/simdref/issues"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:objective-c",
    "onLanguage:objective-cpp",
    "onLanguage:asm"
  ],
  "contributes": {
    "languages": [
      {
        "id": "asm",
        "extensions": [".s", ".S", ".asm", ".inc"],
        "aliases": ["Assembly", "asm"]
      }
    ],
    "commands": [
      {
        "command": "simdref.restartServer",
        "title": "simdref: Restart Server"
      },
      {
        "command": "simdref.reinstallServer",
        "title": "simdref: Reinstall Python Server"
      },
      {
        "command": "simdref.showOutput",
        "title": "simdref: Show Output"
      }
    ],
    "configuration": {
      "title": "simdref",
      "properties": {
        "simdref.serverPath": {
          "type": "string",
          "default": "",
          "description": "Explicit path to the simdref-lsp executable. When empty, the extension manages an isolated virtualenv and installs the bundled server wheel."
        },
        "simdref.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python interpreter used to bootstrap the bundled server. When empty, falls back to python3 / python on PATH."
        },
        "simdref.showPerfMetrics": {
          "type": "boolean",
          "default": true,
          "description": "Include best latency and cycles-per-instruction in hover output."
        },
        "simdref.architectures": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["x86", "arm", "riscv"]
          },
          "default": [],
          "description": "Restrict hover performance rows to the listed architectures. Empty array keeps every arch."
        },
        "simdref.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace LSP communication between VS Code and the simdref language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.4.0"
  }
}
